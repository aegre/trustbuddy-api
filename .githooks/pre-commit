#!/usr/bin/env bash
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

staged_java="$(git diff --cached --name-only --diff-filter=ACM -- '*.java' || true)"

if [ -z "$staged_java" ]; then
	exit 0
fi

file_count="$(printf '%s\n' "$staged_java" | wc -l | tr -d ' ')"
echo "Formatting Java sources (${file_count} staged file(s); running full-tree Spotless)..."
./mvnw spotless:apply -q

printf '%s\n' "$staged_java" | xargs git add --
