# Copy to .env for local development:
#   cp .env.example .env
#
# With profile `dev`, only the variables below are typically needed.
# Base application.yml requires full infra config when not using the dev profile.

# --- Required for local dev (dev profile) ---
POSTGRES_PASSWORD=trustbuddy
AUTH_USERNAME=dev-user
AUTH_PASSWORD=dev-password
JWT_SECRET=dev-secret-change-me-use-at-least-32-characters
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT access token TTL (default 15 minutes)
# JWT_EXPIRATION_MS=900000

# JWT cookie (browser clients; set automatically by POST /api/v1/auth/token)
# JWT_COOKIE_NAME=access_token
# JWT_COOKIE_SECURE=false
# JWT_COOKIE_SAME_SITE=Lax

# Optional dev overrides
# INSURER_GATEWAY_URL=https://tools-httpstatus.pickup-services.com/200
# SERVER_PORT=8080
# Note: host dev uses Kafka on localhost:9094 (see docker-compose dual listeners)

# Sentry (optional locally; required in prod deployment)
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=development
# SENTRY_ENABLED=false

# --- Required for prod (no dev profile) — set in your deployment platform ---
# DATABASE_URL=jdbc:postgresql://host:5432/trustbuddy
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# REDIS_HOST=
# REDIS_PORT=6379
# KAFKA_BOOTSTRAP_SERVERS=
# JWT_SECRET=
# CORS_ALLOWED_ORIGINS=
# INSURER_GATEWAY_URL=
